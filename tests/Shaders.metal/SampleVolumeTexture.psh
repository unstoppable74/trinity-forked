#include "MetalDefines.h"

#include <metal_stdlib>
using namespace metal;

struct VS_OUTPUT
{
	float4 Position [[ position ]];
	float2 TexCoord;
};

struct PerObjectVSData
{
	float layer;
};

fragment float4 mainPS(VS_OUTPUT In [[ stage_in ]], constant PerObjectVSData& PerObjectVS [[ CBUFFER(0) ]], texture3d<float> tex0 [[ texture(0) ]], sampler sampl [[ sampler(0) ]] SHADOW_PS_DECL)
{
    float4 color = tex0.sample( sampl, float3( In.TexCoord, PerObjectVS.layer ) );
    return color;
}
