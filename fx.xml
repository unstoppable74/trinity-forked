<?xml version="1.0" encoding="utf-8"?>
<ProjectSchemaDefinitions xmlns="clr-namespace:Microsoft.Build.Framework.XamlTypes;assembly=Microsoft.Build.Framework" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:transformCallback="Microsoft.Cpp.Dev10.ConvertPropertyCallback">
  <Rule
    Name="BuildFX"
    PageTemplate="tool"
    DisplayName="Build FX"
    Order="200">
    <Rule.DataSource>
      <DataSource
        Persistence="ProjectFile"
        ItemType="BuildFX" />
    </Rule.DataSource>
    <Rule.Categories>
      <Category
        Name="General">
        <Category.DisplayName>
          <sys:String>General</sys:String>
        </Category.DisplayName>
      </Category>
      <Category
        Name="Platforms">
        <Category.DisplayName>
          <sys:String>Platforms</sys:String>
        </Category.DisplayName>
      </Category>
      <Category
        Name="Command Line"
        Subtype="CommandLine">
        <Category.DisplayName>
          <sys:String>Command Line</sys:String>
        </Category.DisplayName>
      </Category>
    </Rule.Categories>
    <EnumProperty 
      Name="OptimizationLevel" 
      DisplayName="Optimization Level"
      Description="Optimization level for HLSL compiler.">
        <EnumValue Name="/O0" DisplayName="0"/>
        <EnumValue Name="/O1" DisplayName="1"/>
        <EnumValue Name="/O2" DisplayName="2"/>
        <EnumValue Name="/O3" DisplayName="3"/>
    </EnumProperty>
    <BoolProperty 
      Name="PlatformDX9" 
      Category="Platforms"
      DisplayName="DirectX 9"
      Description="Compile effect for DirectX 9."/>
    <BoolProperty 
      Name="PlatformDX11" 
      Category="Platforms"
      DisplayName="DirectX 11"
      Description="Compile effect for DirectX 11."/>
    <BoolProperty 
      Name="PlatformGLES2" 
      Category="Platforms"
      DisplayName="OpenGL ES 2"
      Description="Compile effect for OpenGL ES 2."/>
    
    <!--
    <BoolProperty 
      Name="PlatformGLES2" 
      Category="Platforms"
      DisplayName="OpenGL ES 2"
      Description="Compile effect for OpenGL ES 2."/>
      -->
    <StringListProperty
      Name="Inputs"
      Category="Command Line"
      IsRequired="true"
      Switch=" ">
      <StringListProperty.DataSource>
        <DataSource
          Persistence="ProjectFile"
          ItemType="BuildFX"
          SourceType="Item" />
      </StringListProperty.DataSource>
    </StringListProperty>
    <StringProperty
      Name="CommandLineTemplate"
      DisplayName="Command Line"
      Visible="False"
      IncludeInCommandLine="False" />
    <DynamicEnumProperty
      Name="BuildFXBeforeTargets"
      Category="General"
      EnumProvider="Targets"
      Visible="False"
      IncludeInCommandLine="False">
      <DynamicEnumProperty.DisplayName>
        <sys:String>Execute Before</sys:String>
      </DynamicEnumProperty.DisplayName>
      <DynamicEnumProperty.Description>
        <sys:String>Specifies the targets for the build customization to run before.</sys:String>
      </DynamicEnumProperty.Description>
      <DynamicEnumProperty.ProviderSettings>
        <NameValuePair
          Name="Exclude"
          Value="^BuildFXBeforeTargets|^Compute" />
      </DynamicEnumProperty.ProviderSettings>
      <DynamicEnumProperty.DataSource>
        <DataSource
          Persistence="ProjectFile"
          HasConfigurationCondition="true" />
      </DynamicEnumProperty.DataSource>
    </DynamicEnumProperty>
    <DynamicEnumProperty
      Name="BuildFXAfterTargets"
      Category="General"
      EnumProvider="Targets"
      Visible="False"
      IncludeInCommandLine="False">
      <DynamicEnumProperty.DisplayName>
        <sys:String>Execute After</sys:String>
      </DynamicEnumProperty.DisplayName>
      <DynamicEnumProperty.Description>
        <sys:String>Specifies the targets for the build customization to run after.</sys:String>
      </DynamicEnumProperty.Description>
      <DynamicEnumProperty.ProviderSettings>
        <NameValuePair
          Name="Exclude"
          Value="^BuildFXAfterTargets|^Compute" />
      </DynamicEnumProperty.ProviderSettings>
      <DynamicEnumProperty.DataSource>
        <DataSource
          Persistence="ProjectFile"
          ItemType=""
          HasConfigurationCondition="true" />
      </DynamicEnumProperty.DataSource>
    </DynamicEnumProperty>
    <StringProperty
      Subtype="AdditionalOptions"
      Name="AdditionalOptions"
      Category="Command Line">
      <StringProperty.DisplayName>
        <sys:String>Additional Options</sys:String>
      </StringProperty.DisplayName>
      <StringProperty.Description>
        <sys:String>Additional Options</sys:String>
      </StringProperty.Description>
    </StringProperty>
  </Rule>
  <ItemType
    Name="BuildFX"
    DisplayName="Build FX" />
  <FileExtension
    Name="*.fx"
    ContentType="BuildFX" />
  <ContentType
    Name="BuildFX"
    DisplayName="Build FX"
    ItemType="BuildFX" />
</ProjectSchemaDefinitions>