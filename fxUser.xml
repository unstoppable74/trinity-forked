<?xml version="1.0" encoding="utf-8"?>
<Rule
    Name="BuildFXUserSettings"
    DisplayName="Shader Compiler"
    PageTemplate="generic"
    Description="User settings for FX compiler"
    xmlns="http://schemas.microsoft.com/build/2009/properties">
    
    <Rule.DataSource>
        <DataSource Persistence="UserFile" />
    </Rule.DataSource>
    <BoolProperty
      Name="DisplaySkipped"
      DisplayName="Display Skipped Files"
      Description="Specifies whether the compiler should display which files were skipped during incremental build when their output is up to date." />
    <EnumProperty 
      Name="BuildCores" 
      DisplayName="Cores Used"
      Description="Number of cores used when compiling effects.">
        <EnumValue Name="0" DisplayName="Auto" />
        <EnumValue Name="1" DisplayName="1" />
        <EnumValue Name="2" DisplayName="2" />
        <EnumValue Name="3" DisplayName="3" />
        <EnumValue Name="4" DisplayName="4" />
        <EnumValue Name="5" DisplayName="5" />
        <EnumValue Name="6" DisplayName="6" />
        <EnumValue Name="7" DisplayName="7" />
        <EnumValue Name="8" DisplayName="8" />
        <EnumValue Name="9" DisplayName="9" />
        <EnumValue Name="10" DisplayName="10" />
        <EnumValue Name="11" DisplayName="11" />
        <EnumValue Name="12" DisplayName="12" />
        <EnumValue Name="13" DisplayName="13" />
        <EnumValue Name="14" DisplayName="14" />
        <EnumValue Name="15" DisplayName="15" />
        <EnumValue Name="16" DisplayName="16" />
    </EnumProperty>
</Rule>